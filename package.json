{
  "name": "PromptPocket",
  "version": "1.0.0",
  "description": "Chrome extension for managing ChatGPT prompt templates",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run build:ts && npm run build:webpack",
    "build:ts": "tsc",
    "build:webpack": "webpack --mode=production",
    "dev": "webpack --mode=development --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../promptpocket.zip ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.248",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.56.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}